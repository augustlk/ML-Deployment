# Copy this file to .env and fill in your Supabase credentials.
# .env is git-ignored — never commit real secrets.

# Supabase transaction pooler (recommended for containers / Vercel):
DATABASE_URL=Host=aws-0-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.YOUR_REF;Password=YOUR_PASSWORD;SSL Mode=Require

# Supabase direct connection (for migrations / import script):
# DATABASE_URL=Host=db.YOUR_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require
