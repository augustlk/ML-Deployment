@model OrderHistoryViewModel
@{
    ViewData["Title"] = $"Order History — {Model.Customer.FullName}";
}

@await Html.PartialAsync("_CustomerNav", Model.Customer)

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-clock-history me-2"></i>Order History — @Model.Customer.FullName</h4>
    <span class="text-muted small">@Model.TotalCount orders total</span>
</div>

@if (!Model.Orders.Any())
{
    <div class="alert alert-info">
        No orders yet. <a href="/orders/@Model.Customer.CustomerId/new">Place an order →</a>
    </div>
}
else
{
    <div class="accordion" id="orderAccordion">
        @foreach (var o in Model.Orders)
        {
            var collapseId = $"order-{o.OrderId}";
            var badgeClass = o.IsLate switch { true => "danger", false => "success", _ => "secondary" };
            var statusLabel = o.IsLate switch { true => "Late", false => "On Time", _ => "In Transit" };

            <div class="accordion-item mb-2 shadow-sm rounded border">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed rounded" type="button"
                            data-bs-toggle="collapse" data-bs-target="#@collapseId">
                        <div class="d-flex flex-wrap gap-3 align-items-center w-100 me-3">
                            <span class="badge bg-secondary">#@o.OrderId</span>
                            <span class="text-muted small">@o.OrderDate[..10]</span>
                            <strong>$@o.OrderTotal.ToString("N2")</strong>
                            <span class="text-muted small">@o.ItemCount item(s)</span>
                            @if (!string.IsNullOrEmpty(o.Carrier))
                            {
                                <span class="text-muted small"><i class="bi bi-truck me-1"></i>@o.Carrier / @o.ShippingMethod</span>
                            }
                            <span class="badge bg-@badgeClass ms-auto">@statusLabel</span>
                        </div>
                    </button>
                </h2>
                <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#orderAccordion">
                    <div class="accordion-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6>Order Details</h6>
                                <ul class="list-unstyled small text-muted">
                                    @if (!string.IsNullOrEmpty(o.PaymentMethod))
                                    {
                                        <li><i class="bi bi-credit-card me-1"></i>Payment: @o.PaymentMethod</li>
                                    }
                                    @if (!string.IsNullOrEmpty(o.PromoCode))
                                    {
                                        <li><i class="bi bi-tag me-1"></i>Promo: @o.PromoCode</li>
                                    }
                                    @if (o.PromisedDays.HasValue)
                                    {
                                        <li><i class="bi bi-calendar-check me-1"></i>Promised: @o.PromisedDays days | Actual: @(o.ActualDays?.ToString() ?? "pending")</li>
                                    }
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6>Items</h6>
                                <table class="table table-sm">
                                    <thead><tr><th>Product</th><th>Qty</th><th>Unit</th><th>Total</th></tr></thead>
                                    <tbody>
                                        @foreach (var item in o.Items)
                                        {
                                            <tr>
                                                <td>@item.ProductName</td>
                                                <td>@item.Quantity</td>
                                                <td>$@item.UnitPrice.ToString("N2")</td>
                                                <td>$@item.LineTotal.ToString("N2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" href="/orders/@Model.Customer.CustomerId?page=@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
