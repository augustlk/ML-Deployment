@model WarehouseViewModel
@{
    ViewData["Title"] = "Fraud Risk Priority Queue";
}

<div class="d-flex flex-wrap align-items-center gap-3 mb-4">
    <div>
        <h2 class="mb-0"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Fraud Risk Priority Queue</h2>
        <p class="text-muted mb-0 small">
            Top 50 orders ranked by predicted fraud probability
            &nbsp;|&nbsp;
            Model: <strong>@Model.ScoringModelName</strong>
            @if (Model.LastScoredAt.HasValue)
            {
                <span>&nbsp;|&nbsp;Last scored: @Model.LastScoredAt.Value.ToString("yyyy-MM-dd HH:mm") UTC</span>
            }
            else
            {
                <span class="text-warning">&nbsp;|&nbsp;Not yet scored — click "Run Scoring" to populate.</span>
            }
        </p>
    </div>
    <div class="ms-auto">
        <form method="post" action="/warehouse/score" id="scoringForm">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger" id="scoreBtn">
                <i class="bi bi-cpu me-2"></i>Run Scoring
            </button>
        </form>
    </div>
</div>

<!-- Legend -->
<div class="d-flex gap-3 mb-3 small">
    <span><span class="badge bg-danger">■</span> High risk ≥ 70%</span>
    <span><span class="badge bg-warning text-dark">■</span> Medium risk 40–70%</span>
    <span><span class="badge bg-success">■</span> Low risk &lt; 40%</span>
</div>

@if (!Model.PriorityQueue.Any())
{
    <div class="alert alert-secondary text-center py-5">
        <i class="bi bi-inbox fs-1 d-block mb-3 text-muted"></i>
        <h5>No scoring results yet</h5>
        <p class="text-muted mb-3">Click <strong>Run Scoring</strong> to generate the priority queue.</p>
        <form method="post" action="/warehouse/score">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-cpu me-2"></i>Run Scoring Now
            </button>
        </form>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Order Date</th>
                    <th>Total</th>
                    <th>Carrier</th>
                    <th>Method</th>
                    <th>Distance</th>
                    <th>Promised Days</th>
                    <th>Fraud Probability</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.PriorityQueue)
                {
                    <tr class="@(row.LateDeliveryProbability >= 0.7f ? "table-danger" : row.LateDeliveryProbability >= 0.4f ? "table-warning" : "")">
                        <td class="fw-bold text-muted">@row.Rank</td>
                        <td>
                            <span class="badge bg-secondary">#@row.OrderId</span>
                        </td>
                        <td>
                            <a href="/dashboard/@row.CustomerId" class="text-decoration-none">
                                @row.CustomerName
                            </a>
                        </td>
                        <td class="text-muted small">
                            @(row.OrderDate.Length >= 10 ? row.OrderDate[..10] : row.OrderDate)
                        </td>
                        <td>$@row.OrderTotal.ToString("N2")</td>
                        <td>@(row.Carrier ?? "—")</td>
                        <td>@(row.ShippingMethod ?? "—")</td>
                        <td>@(row.DistanceBand ?? "—")</td>
                        <td>@(row.PromisedDays?.ToString() ?? "—")</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:8px; min-width:80px">
                                    <div class="progress-bar bg-@row.ProbabilityBadgeClass"
                                         style="width:@((row.LateDeliveryProbability * 100).ToString("F0"))%"></div>
                                </div>
                                <span class="badge bg-@row.ProbabilityBadgeClass">
                                    @((row.LateDeliveryProbability * 100).ToString("F1"))%
                                </span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- JSON export link for ML pipeline / downstream consumers -->
    <div class="mt-3 text-muted small">
        <i class="bi bi-braces me-1"></i>
        Raw JSON available at
        <a href="/api/warehouse/priority-queue" target="_blank">/api/warehouse/priority-queue</a>
        — useful for the ML pipeline, BI tools, or downstream consumers.
    </div>
}

@section Scripts {
<script>
// Provide visual feedback while scoring runs (can take a moment on large DBs)
document.getElementById('scoringForm')?.addEventListener('submit', () => {
    const btn = document.getElementById('scoreBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Scoring…';
});
</script>
}
