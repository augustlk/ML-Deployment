@* Reusable breadcrumb / sub-nav for customer-scoped pages *@
@model ShopApp.Web.Models.Entities.Customer

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Customers</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.FullName</li>
    </ol>
</nav>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/dashboard/@Model.CustomerId"
       class="btn btn-sm @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "btn-dark" : "btn-outline-dark")">
        <i class="bi bi-speedometer2 me-1"></i>Dashboard
    </a>
    <a href="/orders/@Model.CustomerId"
       class="btn btn-sm @(ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "btn-dark" : "btn-outline-dark")">
        <i class="bi bi-clock-history me-1"></i>Order History
    </a>
    <a href="/orders/@Model.CustomerId/new"
       class="btn btn-sm btn-success">
        <i class="bi bi-plus-circle me-1"></i>New Order
    </a>
</div>
