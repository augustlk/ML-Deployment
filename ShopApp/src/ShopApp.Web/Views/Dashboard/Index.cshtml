@model DashboardViewModel
@{
    ViewData["Title"] = $"Dashboard — {Model.Customer.FullName}";
}

@await Html.PartialAsync("_CustomerNav", Model.Customer)

<h2 class="mb-1">@Model.Customer.FullName</h2>
<p class="text-muted mb-4">
    <i class="bi bi-envelope me-1"></i>@Model.Customer.Email
    &nbsp;|&nbsp;
    <i class="bi bi-geo-alt me-1"></i>@Model.Customer.City, @Model.Customer.State
    &nbsp;|&nbsp;
    Segment: <strong>@Model.Customer.CustomerSegment</strong>
    &nbsp;|&nbsp;
    Tier: <strong>@Model.Customer.LoyaltyTier</strong>
</p>

<!-- Stats cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card text-center stat-card shadow-sm">
            <div class="card-body">
                <div class="stat-number">@Model.TotalOrders</div>
                <div class="stat-label">Total Orders</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center stat-card shadow-sm">
            <div class="card-body">
                <div class="stat-number">$@Model.TotalSpend.ToString("N0")</div>
                <div class="stat-label">Total Spent</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center stat-card shadow-sm">
            <div class="card-body">
                <div class="stat-number">$@Model.AverageOrderValue.ToString("N2")</div>
                <div class="stat-label">Avg Order Value</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card text-center stat-card shadow-sm @(Model.LateDeliveries > 0 ? "border-warning" : "")">
            <div class="card-body">
                <div class="stat-number @(Model.LateDeliveries > 0 ? "text-warning" : "text-success")">
                    @Model.LateDeliveries
                </div>
                <div class="stat-label">Late Deliveries</div>
            </div>
        </div>
    </div>
</div>

<!-- Recent orders -->
<h5 class="mb-3"><i class="bi bi-clock-history me-2"></i>Recent Orders</h5>
@if (!Model.RecentOrders.Any())
{
    <div class="alert alert-info">No orders yet. <a href="/orders/@Model.Customer.CustomerId/new">Place the first one →</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Order #</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Carrier</th>
                    <th>Method</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr>
                        <td><span class="badge bg-secondary">#@o.OrderId</span></td>
                        <td class="text-muted small">@o.OrderDate[..10]</td>
                        <td>@o.ItemCount</td>
                        <td>$@o.OrderTotal.ToString("N2")</td>
                        <td>@(o.Carrier ?? "—")</td>
                        <td>@(o.ShippingMethod ?? "—")</td>
                        <td>
                            @{
                                var badgeClass = o.DeliveryStatus switch
                                {
                                    "Late" => "danger",
                                    "On Time" => "success",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@badgeClass">@o.DeliveryStatus</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <a href="/orders/@Model.Customer.CustomerId" class="btn btn-outline-dark btn-sm">
        View full order history →
    </a>
}
